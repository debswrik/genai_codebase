import os
import sys
import torch
import transformers
import transformers.models.auto.modeling_auto as modeling_auto

# 🛠️ PATCH 1: TRANSFORMERS_CACHE bridge
if not hasattr(transformers.utils.hub, "TRANSFORMERS_CACHE"):
    transformers.utils.hub.TRANSFORMERS_CACHE = os.path.join(os.path.expanduser("~"), ".cache", "huggingface", "hub")

# 🛠️ PATCH 2: Vision mapping shim
if not hasattr(modeling_auto, "MODEL_FOR_VISION_2_SEQ_MAPPING_NAMES"):
    modeling_auto.MODEL_FOR_VISION_2_SEQ_MAPPING_NAMES = {}

# 🚀 CORE IMPORTS
from datasets import load_dataset
from transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig, logging
from peft import LoraConfig, TaskType
from trl import DPOTrainer, DPOConfig
from huggingface_hub import login

# 🔑 AUTH
try:
    from kaggle_secrets import UserSecretsClient
    hf_token = UserSecretsClient().get_secret("HF_TOKEN")
    if hf_token: login(token=hf_token)
except Exception: pass

logging.set_verbosity_warning()
os.environ["PYTORCH_CUDA_ALLOC_CONF"] = "expandable_segments:True"
print("🔥 GenAI Stack Loaded & Patched.")


model_name   = "NousResearch/Llama-2-7b-chat-hf"
dataset_name = "Intel/orca_dpo_pairs"

# LoRA & BitsAndBytes Config
lora_r, lora_alpha, lora_dropout = 8, 16, 0.05
target_modules = ["q_proj", "v_proj"]

# DPO Hyperparameters
beta, max_length, max_prompt_length = 0.1, 512, 256
learning_rate = 5e-5
num_train_epochs = 1
per_device_train_batch_size = 1
gradient_accumulation_steps = 4


# dataset = load_dataset(dataset_name, split="train")
dataset = load_dataset(dataset_name, split="train").select(range(500))

def format_dpo_dataset(example):
    system = example.get("system", "")
    question = example["question"]
    prompt = f"<s>[INST] <<SYS>>\n{system}\n<</SYS>>\n\n{question} [/INST]" if system else f"<s>[INST] {question} [/INST]"
    return {"prompt": prompt, "chosen": example["chosen"], "rejected": example["rejected"]}

dataset = dataset.map(format_dpo_dataset).select_columns(["prompt", "chosen", "rejected"])
dataset = dataset.train_test_split(test_size=0.05, seed=42)
print(f"✅ Data Formatted: {len(dataset['train'])} train samples.")


bnb_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_quant_type="nf4",
    bnb_4bit_compute_dtype=torch.float16,
    bnb_4bit_use_double_quant=True,
)

model = AutoModelForCausalLM.from_pretrained(
    model_name,
    quantization_config=bnb_config,
    device_map="auto",
    dtype=torch.float16, # Fixed deprecation
    low_cpu_mem_usage=True
)

# 🛠️ THE MONKEY PATCH: Fixes the AttributeError in DPOTrainer
if not hasattr(model, "warnings_issued"):
    model.warnings_issued = {}

model.gradient_checkpointing_enable()
model.enable_input_require_grads()
model.config.use_cache = False
model.config.pretraining_tp = 1

tokenizer = AutoTokenizer.from_pretrained(model_name)
tokenizer.pad_token = tokenizer.eos_token
tokenizer.padding_side = "right"
print("🚀 Model ready.")


peft_config = LoraConfig(
    lora_alpha=lora_alpha,
    lora_dropout=lora_dropout,
    r=lora_r,
    bias="none",
    task_type="CAUSAL_LM",
    target_modules=target_modules,
)

dpo_config = DPOConfig(
    beta=beta,
    max_length=max_length,
    max_prompt_length=max_prompt_length,
    output_dir="./dpo_results",
    num_train_epochs=num_train_epochs,
    per_device_train_batch_size=per_device_train_batch_size,
    gradient_accumulation_steps=gradient_accumulation_steps,
    gradient_checkpointing=True,
    learning_rate=learning_rate,
    optim="paged_adamw_32bit",
    fp16=True,
    max_steps=-1,
    logging_steps=10,
    save_steps=0,
    eval_strategy="steps",
    eval_steps=50,
    remove_unused_columns=False
)

trainer = DPOTrainer(
    model,
    ref_model=None,
    args=dpo_config,
    train_dataset=dataset["train"],
    eval_dataset=dataset["test"],
    processing_class=tokenizer, # Fixed naming for 0.15.0+
    peft_config=peft_config,
)

print("✨ Starting DPO Training Loop...")
trainer.train()


from huggingface_hub import notebook_login
notebook_login()


hf_username = "debsubhra" 
dataset_repo = f"{hf_username}/orca-dpo-mini-500"

# Push to Hub
dataset.push_to_hub(dataset_repo)
print(f"Dataset is live at: https://huggingface.co/datasets/{dataset_repo}")


model_repo = f"{hf_username}/llama2-7b-dpo-orca-mini"

# Push the adapter and the tokenizer
model.push_to_hub(model_repo)
tokenizer.push_to_hub(model_repo)

print(f"Model Adapters are live at: https://huggingface.co/{model_repo}")


